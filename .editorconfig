dotnet_diagnostic.CA1827.severity = none

# CA1824: Mark assemblies with NeutralResourcesLanguageAttribute — deferred to Phase C
dotnet_diagnostic.CA1824.severity = none

# CA1715: Identifiers should have correct prefix — deferred to Phase C
dotnet_diagnostic.CA1715.severity = none

# CA1725: Parameter names should match base declaration — deferred to Phase C
dotnet_diagnostic.CA1725.severity = none

# IDE0045: Convert if-else to conditional — deferred to Phase C (C8)
dotnet_diagnostic.IDE0045.severity = none

# IDE0060: Remove unused parameter — deferred to Phase C
dotnet_diagnostic.IDE0060.severity = none

# ---------------------------------------------------------------------------
# XML doc warnings — deferred to Phase E (Task E1: XML doc comments on all
# public API surface). At E1 these get re-enabled as errors so the
# doc-completeness gate bites.
# ---------------------------------------------------------------------------

# CS1572: XML comment has a param tag for a parameter that doesn't exist — Phase E re-enables
dotnet_diagnostic.CS1572.severity = none

# CS1573: Parameter has no matching param tag in XML comment — Phase E re-enables
dotnet_diagnostic.CS1573.severity = none

# CS1574: XML comment has cref attribute that couldn't be resolved — Phase E re-enables
dotnet_diagnostic.CS1574.severity = none
