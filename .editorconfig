dotnet_diagnostic.CA1310.severity = none

# CA1834: Prefer Append(char) over Append(string) for single chars — deferred to Phase C (C8)
dotnet_diagnostic.CA1834.severity = none

# CA1861: Prefer static readonly arrays — deferred to Phase C (C8)
dotnet_diagnostic.CA1861.severity = none

