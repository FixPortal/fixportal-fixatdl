# Formatter-only keys. All analyzer/style RULES come from the FixPortal.CodeStyle
# package's global config — do not duplicate them here. Add a local rule override
# ONLY for a genuine project-specific need, with a comment why.

root = true

#### Baseline (applies to every file type) ####
[*]
charset = utf-8
indent_style = space
indent_size = 4
tab_width = 4
trim_trailing_whitespace = true
insert_final_newline = true

#### Project / config files (2-space convention) ####
[*.{csproj,fsproj,vbproj,proj,props,targets}]
indent_size = 2

[*.{json,yml,yaml,xml,config}]
indent_size = 2

[*.md]
# markdown line breaks are two trailing spaces — don't trim them
trim_trailing_whitespace = false

#### C# files (formatter keys only) ####
[*.cs]
end_of_line = crlf
indent_size = 4
indent_style = space
tab_width = 4

# New line preferences
csharp_new_line_before_catch = true
csharp_new_line_before_else = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_anonymous_types = false
csharp_new_line_before_members_in_object_initializers = false
csharp_new_line_before_open_brace = all
csharp_new_line_between_query_expression_clauses = true

# Indentation preferences
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_case_contents_when_block = true
csharp_indent_labels = one_less_than_current
csharp_indent_switch_labels = true

# Space preferences
csharp_space_after_cast = false
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_after_comma = true
csharp_space_after_dot = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_after_semicolon_in_for_statement = true
csharp_space_around_binary_operators = before_and_after
csharp_space_around_declaration_statements = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_before_comma = false
csharp_space_before_dot = false
csharp_space_before_open_square_brackets = false
csharp_space_before_semicolon_in_for_statement = false
csharp_space_between_empty_square_brackets = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_name_and_open_parenthesis = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_parentheses = false
csharp_space_between_square_brackets = false

# Wrapping preferences
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = false

#### Project-specific rule overrides ####
# Each entry below overrides the FixPortal.CodeStyle global config for a reason
# specific to this FIXatdl parser/model library. Do not add entries without one.

# ReSharper/Rider naming highlight — FIXatdl spec type names carry a mandatory
# '_t' suffix (Clock_t, Qty_t, …) that trips InconsistentNaming; analyzer-side
# equivalents (S101, CA1707) are handled below / in the package.
resharper_inconsistent_naming_highlighting = none

# S101 — "type name should be PascalCase". Every FIXatdl element/type/control name
#   carries the spec's mandatory '_t' suffix (Clock_t, Qty_t, Strategy_t, …). The
#   suffix is part of the XML xsi:type contract, not a style slip; renaming would
#   break the spec-to-CLR mapping. (~128 occurrences, the bulk of the warnings.)
dotnet_diagnostic.S101.severity = none

# S2225 — "ToString() should not return null". For the FIXatdl value/control types a
#   null ToString result is the protocol signal "omit this field from the FIX wire"
#   (a non-present optional tag), distinct from an empty string. Returning "" would
#   change wire semantics.
dotnet_diagnostic.S2225.severity = none

# S3925 — "implement the full ISerializable pattern". Demands the legacy
#   (SerializationInfo, StreamingContext) constructor for BinaryFormatter-style
#   serialization, which is obsolete and disabled on modern .NET. The exceptions are
#   never binary-serialized; the pattern would be dead ceremony.
dotnet_diagnostic.S3925.severity = none

# S2094 — "remove this empty class". The empty types are intentional spec markers
#   (e.g. TagNum_t : NonZeroPositiveIntegerTypeBase) that give each FIXatdl type a
#   distinct CLR identity for the xsi:type dispatch; they are deliberately bodyless.
dotnet_diagnostic.S2094.severity = none

# S2743 — "static field in a generic type is not shared across closed types". The
#   per-closed-type behaviour is exactly what AtdlValueType<T>/AtdlReferenceType<T>
#   rely on (one cache slot per concrete value type). The rule's concern is the
#   intended design here.
dotnet_diagnostic.S2743.severity = none

# CA1062 — "validate arguments of public methods". Package default is suggestion;
#   suppressed here by design: this is a parser/model library whose public surface is
#   reached almost entirely through the nullable-annotated model graph, and the few
#   genuine entry points (StrategiesReader, value/control converters) already fail
#   fast via ThrowHelper with FIXatdl-specific exceptions. Blanket ArgumentNullException
#   guards on every externally-visible member would be ~85 sites of dead ceremony that
#   change wire/error semantics for no real safety gain.
dotnet_diagnostic.CA1062.severity = none

#### Test project overrides ####
[*Tests.cs]
# CA2007 (ConfigureAwait) is actively wrong in xUnit test methods — it trips xUnit1030
# (ConfigureAwait(false) can bypass the runner's parallelism limits). Never suggest it here.
dotnet_diagnostic.CA2007.severity = none

[**/tests/**.cs]
# Same xUnit1030 rationale as above, scoped to the tests tree.
dotnet_diagnostic.CA2007.severity = none
