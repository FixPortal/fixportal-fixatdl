{
  "stryker-config": {
    "solution": "FixPortal.FixAtdl.slnx",
    "project": "src/FixPortal.FixAtdl/FixPortal.FixAtdl.csproj",
    "test-projects": [
      "tests/FixPortal.FixAtdl.Tests/FixPortal.FixAtdl.Tests.csproj"
    ],
    "reporters": [
      "progress",
      "html",
      "json"
    ],
    "report-file-name": "mutation-report",
    "mutation-level": "Standard",
    "coverage-analysis": "perTest",
    "test-runner": "mtp",
    "concurrency": 4,
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "test-case-filter": "Category!=Integration",
    "mutate": [
      "**/*.cs"
    ]
  }
}
